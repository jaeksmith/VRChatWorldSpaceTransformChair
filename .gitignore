# =========================
# Unity project (at Unity/VRChatWorldSpaceTransformChair/)
# =========================
Unity/VRChatWorldSpaceTransformChair/[Ll]ibrary/
Unity/VRChatWorldSpaceTransformChair/[Tt]emp/
Unity/VRChatWorldSpaceTransformChair/[Oo]bj/
Unity/VRChatWorldSpaceTransformChair/[Bb]uild/
Unity/VRChatWorldSpaceTransformChair/[Bb]uilds/
Unity/VRChatWorldSpaceTransformChair/[Ll]ogs/
Unity/VRChatWorldSpaceTransformChair/[Uu]ser[Ss]ettings/
Unity/VRChatWorldSpaceTransformChair/[Mm]emoryCaptures/
Unity/VRChatWorldSpaceTransformChair/[Rr]ecordings/
Unity/VRChatWorldSpaceTransformChair/Assets/Plugins/Editor/JetBrains*

# VRChat ClientSim runtime cache (per-machine, regenerated on Play).
Unity/VRChatWorldSpaceTransformChair/ClientSimStorage/

# Unity meta files are kept (they're important for Unity)
# but OS-generated files for non-asset binaries are not
Unity/VRChatWorldSpaceTransformChair/*.pidb.meta
Unity/VRChatWorldSpaceTransformChair/*.pdb.meta
Unity/VRChatWorldSpaceTransformChair/*.mdb.meta

# Unity asset store tools
Unity/VRChatWorldSpaceTransformChair/Assets/AssetStoreTools*

# Unity-generated solution / project files (regenerated by Unity)
Unity/VRChatWorldSpaceTransformChair/*.csproj
Unity/VRChatWorldSpaceTransformChair/*.sln

# Unity SerializedUdonPrograms — generated by UdonSharp on compile
Unity/VRChatWorldSpaceTransformChair/Assets/SerializedUdonPrograms/

# Manual scene backups (e.g. DevScene001.backup.001.unity) — local snapshots only
*.backup.*.unity
*.backup.*.unity.meta

# =========================
# TempHandOffs/  — workspace folder for handing files to Claude.
# Items get processed and moved to their permanent home; nothing in
# this folder should be tracked.
# =========================
TempHandOffs/

# =========================
# IDE / Editor
# =========================
.vs/
.vscode/
*.swp
*.sln.docstates
.idea/
*.user
*.suo
*.cache
*.DotSettings.user

# =========================
# OS generated
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =========================
# Claude Code
# =========================
# Default: ignore Claude Code's project directory (machine-local settings,
# session state, cache, etc.). Exception: the memory/ subdir holds curated
# project-context notes — they're junctioned here from the user's
# ~/.claude/projects/<encoded-path>/memory/ so that context survives
# across machines and collaborators.
.claude/*
!.claude/memory/
!.claude/memory/**

# Per-thread transient run-state notes (crash-recovery scratchpad).
# Lives under .claude/transient/ — not tracked.
.claude/transient/

# =========================
# Misc
# =========================
*.log
*.tmp
